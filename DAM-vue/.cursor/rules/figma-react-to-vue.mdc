// 2. 在 list.vue 中使用
import { useDynaVxeGrid } from '#/adapter/vxe-table';
import { useGridFormSchema } from './data';

const [Grid, gridApi] = useDynaVxeGrid({
  formOptions: {
    // 时间字段映射：将 createTime 映射为 startTime 和 endTime
    fieldMappingTime: [['createTime', ['startTime', 'endTime']]],
    // 搜索表单 schema
    schema: useGridFormSchema(),
    // 表单值改变时自动提交搜索（可选）
    submitOnChange: true,
  },
  gridOptions: {
    columns: useColumns(),
    proxyConfig: {
      ajax: {
        // formValues 会自动包含表单搜索条件
        query: async ({ page, sorts }, formValues) => {
          return await getList(
            {
              pageNum: page.currentPage,
              pageSize: page.pageSize,
            },
            {
              // 表单搜索值会自动传入
              ...formValues,
            },
          );
        },
      },
    },
  },
});

// 使用
<Grid />
```

**规则**：
- 所有表格场景使用 `useDynaVxeGrid`
- 列定义使用 VXE Table 格式（`field`, `title`, `width` 等）
- 分页、排序、筛选通过 `gridOptions` 配置
- **表格搜索表单使用 `formOptions` 配置**：
  - `schema`: 使用 `useGridFormSchema()` 函数生成表单 schema
  - `fieldMappingTime`: 时间字段映射，格式为 `[['字段名', ['开始时间字段', '结束时间字段']]]`
  - `submitOnChange`: 是否在表单值改变时自动提交搜索（默认 false）
- 在 `proxyConfig.ajax.query` 中，表单值作为第二个参数 `formValues` 传入
- 搜索表单 schema 应单独定义 `useGridFormSchema()` 函数，与编辑表单 schema 分离

### 4. 表单转换

#### Form → useDynaForm（配置式表单）

**⚠️ 重要规则：所有表单必须采用配置形式，禁止使用手动编写的表单组件。**

**核心要求：**
- **所有表单必须使用 `useDynaForm` + schema 配置形式**
- **Schema 必须定义在 `data.ts` 中的 `useFormSchema()` 函数**
- **表单组件必须抽离为独立组件（`modules/form.vue`）**
- **在 `list.vue` 中使用 `useDynaDrawer`/`useDynaModal` 的 `connectedComponent` 参数连接表单组件**
- **禁止在表单组件中手动编写 `<Input>`、`<Select>` 等表单字段**
- **禁止使用 `defineExpose` 暴露 `getFormData`/`setFormData` 方法**

```typescript
// React (Figma)
import { Form, Input, Select } from 'antd';

<Form form={form} onFinish={handleSubmit}>
  <Form.Item name="name" label="名称">
    <Input />
  </Form.Item>
  <Form.Item name="type" label="类型">
    <Select options={options} />
  </Form.Item>
</Form>

// Vue (项目规范)
// 1. 在 data.ts 中定义表单 schema
import type { DynaFormSchema } from '#/adapter/form';
import { z } from '#/adapter/form';
import { getRoleList } from '#/api';
import { $t } from '#/locales';

export function useFormSchema(): DynaFormSchema[] {
  return [
    {
      component: 'Input',
      fieldName: 'account',
      label: $t('system.user.account'),
      rules: z
        .string()
        .min(1, {
          message: $t('ui.formRules.required', [$t('system.user.account')]),
        })
        .regex(/^[a-z0-9]{8,12}$/i, {
          message: $t('ui.formRules.formatPatternAccount', [
            $t('system.user.account'),
            $t('ui.formRules.formatDescriptions.accountRange'),
          ]),
        }),
    },
    {
      component: 'ApiSelect',
      fieldName: 'roleId',
      label: $t('system.user.roleName'),
      componentProps: {
        api: getRoleList,
        params: {
          status: 1,
        },
        labelField: 'roleName',
        valueField: 'roleId',
        class: 'w-full',
      },
      rules: 'selectRequired',
    },
    {
      component: 'ApiTreeSelect',
      componentProps: {
        allowClear: true,
        api: async () => {
          const data = await getOrganizeList();
          return data.map((node: any) => ({
            ...node,
            disabled: node.children && node.children.length > 0,
          }));
        },
        labelField: 'name',
        valueField: 'organizeId',
        childrenField: 'children',
      },
      fieldName: 'department',
      label: $t('system.user.department'),
    },
  ];
}

// 2. 在 modules/form.vue 中使用（参考 apps/lab-admin/src/views/system/user/modules/form.vue）
<script lang="ts" setup>
import { computed, ref } from 'vue';
import { useDynaDrawer } from '@dyna/common-ui';
import { message } from 'ant-design-vue';
import { useDynaForm } from '#/adapter/form';
import { addUser, getUserInfoById, updateUser } from '#/api';
import { $t } from '#/locales';
import { useFormSchema } from '../data';

// 如果某个字段交互过于复杂，可通过插槽自定义渲染
// 在 Form 组件中使用 <template #fieldName="{ field }"> 插槽

const emits = defineEmits(['success']);
const formData = ref();
const userId = ref();

/**
 * 根据是否有 reportId 来决定是否显示某些字段
 * 编辑模式可能需要隐藏或禁用某些字段
 */
const formSchema = computed(() => {
  const schema = useFormSchema();
  // 编辑模式过滤某些字段（根据业务需求调整）
  if (reportId.value) {
    return schema.filter((item) => item.fieldName !== 'password');
  }
  return schema;
});

const [Form, formApi] = useDynaForm({
  schema: formSchema.value,
  showDefaultActions: false,
  commonConfig: {
    labelWidth: 90,
  },
  wrapperClass: 'grid-cols-1',
  layout: 'vertical',
});

const [Drawer, drawerApi] = useDynaDrawer({
  /**
   * 确认提交表单
   * 验证表单后调用新增或更新接口
   */
  async onConfirm() {
    const { valid } = await formApi.validate();
    if (!valid) return;
    const values = await formApi.getValues();

    drawerApi.lock();
    try {
      await (reportId.value
        ? updateReport({ id: reportId.value, ...values })
        : addReport(values));
      message.success($t('ui.actionMessage.operationSuccess'));
      drawerApi.close();
      emits('success');
    } finally {
      drawerApi.unlock();
    }
  },

  /**
   * 抽屉打开/关闭状态变化处理
   * 打开时初始化表单数据，关闭时重置表单
   * @param isOpen 是否打开
   */
  async onOpenChange(isOpen) {
    if (isOpen) {
      const data = drawerApi.getData();
      formApi.resetForm();

      // 编辑模式：通过 id 获取详情数据
      if (data && data.id) {
        try {
          const reportInfo = await getReportById({ id: data.id });
          formData.value = reportInfo;
          reportId.value = reportInfo.id;
          formApi.setValues(reportInfo);
          // 动态更新 schema（如隐藏、禁用字段）
          formApi.updateSchema([
            {
              fieldName: 'code',
              disabled: true,
            },
          ]);
        } catch {}
      } else {
        // 新增模式：重置表单
        reportId.value = undefined;
      }
    }
  },
});

const getDrawerTitle = computed(() => {
  return sampleId.value
    ? $t('ui.actionTitle.edit', [$t('lab.sample.key')])
    : $t('ui.actionTitle.create', [$t('lab.sample.key')]);
});
</script>

<template>
  <Drawer :title="getDrawerTitle">
    <Form>
      <!-- 复杂字段自定义插槽示例 -->
      <!-- <template #fieldName="{ field }">
        <CustomComponent v-bind="field" />
      </template> -->
    </Form>
  </Drawer>
</template>

