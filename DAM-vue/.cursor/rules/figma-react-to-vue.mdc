#### 2. modules/form.vue - 表单组件（参考 apps/lab-admin/src/views/system/user/modules/form.vue）

```vue
<script lang="ts" setup>
import { computed, ref } from 'vue';
import { useDynaDrawer } from '@dyna/common-ui';
import { message } from 'ant-design-vue';
import { useDynaForm } from '#/adapter/form';
import { addUser, getUserInfoById, updateUser } from '#/api';
import { $t } from '#/locales';
import { useFormSchema } from '../data';

const emits = defineEmits(['success']);
const formData = ref();
const userId = ref();

// 根据业务逻辑动态调整 schema（如新增/编辑模式）
const formSchema = computed(() => {
  const schema = useFormSchema();
  // 编辑模式过滤某些字段
  if (userId.value) {
    return schema.filter((item) => item.fieldName !== 'password');
  }
  return schema;
});

const [Form, formApi] = useDynaForm({
  schema: formSchema.value,
  showDefaultActions: false,
  commonConfig: {
    labelWidth: 90,
  },
  wrapperClass: 'grid-cols-1',
  layout: 'vertical',
});

// 使用 inject 模式获取 drawerApi（通过 connectedComponent 传递）
const [Drawer, drawerApi] = useDynaDrawer({
  async onConfirm() {
    const { valid } = await formApi.validate();
    if (!valid) return;
    const values = await formApi.getValues();

    drawerApi.lock();
    try {
      await (userId.value
        ? updateUser({ userId: userId.value, ...values })
        : addUser(values));
      message.success($t('ui.actionMessage.operationSuccess'));
      drawerApi.close();
      emits('success');
    } finally {
      drawerApi.unlock();
    }
  },

  async onOpenChange(isOpen) {
    if (isOpen) {
      const data = drawerApi.getData();
      formApi.resetForm();

      if (data && data.userId) {
        try {
          const userInfo = await getUserInfoById({ userId: data.userId });
          formData.value = userInfo;
          userId.value = userInfo.userId;
          formApi.setValues(userInfo);
        } catch {}
      }
    }
  },
});
</script>

<template>
  <Drawer :title="getDrawerTitle">
    <Form>
      <!-- 复杂字段自定义插槽示例 -->
      <!-- <template #fieldName="{ field }">
        <CustomComponent v-bind="field" />
      </template> -->
    </Form>
  </Drawer>
</template>
```

