### Vue (项目规范)

#### 1. api/*.ts - 定义 API 接口和数据类型（参考 apps/lab-admin/src/api/system/user.ts）

**⚠️ 重要：表格列表、新增、编辑、删除接口，必须增加对应的 API 文件**

```typescript
import type { PaginationQuery, Recordable } from '@dyna/types';

import { apiPath } from '#/api/constants';
import { requestClient } from '#/api/request';

/**
 * 数据类型定义（参考 SQL 数据结构）
 * 使用 namespace 导出，便于类型管理和命名空间隔离
 */
export namespace LabReportApi {
  /**
   * 检测报告数据接口
   * 字段定义参考数据库表结构
   */
  export interface ReportData {
    [key: string]: any;
    /** 报告ID */
    id: number;
    /** 样品名称 */
    sampleName: string;
    /** 样品编号 */
    sampleCode: string;
    /** 采样点编号 */
    samplingPoint: string;
    /** 采样时间 */
    samplingTime: string;
    /** 装置 */
    device: string;
    /** 检测项列表 */
    testItems: TestItem[];
    /** 创建时间 */
    createTime?: string;
    /** 更新时间 */
    updateTime?: string;
  }

  /**
   * 检测项数据接口
   */
  export interface TestItem {
    /** 检测项编号 */
    code: string;
    /** 检测项名称 */
    name: string;
    /** 状态 */
    status: string;
    /** 分析项列表 */
    analysisItems: AnalysisItem[];
  }

  /**
   * 分析项数据接口
   */
  export interface AnalysisItem {
    /** 分析项名称 */
    name: string;
    /** 检测值 */
    testValue: string;
    /** 单位 */
    unit: string;
    /** 标准值 */
    standardValue: string;
    /** 检测人员 */
    testPerson?: string;
  }

  /**
   * 列表查询参数接口
   */
  export interface ReportListParams {
    /** 样品名称 */
    sampleName?: string;
    /** 样品编号 */
    sampleCode?: string;
    /** 采样点编号 */
    samplingPoint?: string;
    /** 开始时间 */
    startTime?: string;
    /** 结束时间 */
    endTime?: string;
    /** 装置 */
    device?: string;
  }
}

/**
 * 获取检测报告列表数据
 * @param params 分页排序参数
 * @param data 查询参数（表单搜索条件）
 * @returns 返回分页数据，格式为 { rows: ReportData[], total: number }
 */
function getReportList(params: PaginationQuery, data: LabReportApi.ReportListParams) {
  return requestClient.post<{ rows: LabReportApi.ReportData[]; total: number }>(
    apiPath.system('lab/report/list'),
    data,
    {
      params,
    },
  );
}

/**
 * 根据ID获取检测报告详情
 * @param params 查询参数，包含 id
 * @returns 返回报告详情数据
 */
function getReportById(params: { id: number }) {
  return requestClient.get<LabReportApi.ReportData>(
    apiPath.system('lab/report/get'),
    { params },
  );
}

/**
 * 新增检测报告
 * @param data 报告数据
 * @returns 返回操作结果
 */
async function addReport(data: Omit<LabReportApi.ReportData, 'id' | 'createTime' | 'updateTime'>) {
  return requestClient.post(apiPath.system('lab/report/save'), data);
}

/**
 * 更新检测报告
 * @param data 报告数据（必须包含 id）
 * @returns 返回操作结果
 */
async function updateReport(data: LabReportApi.ReportData) {
  return requestClient.post(apiPath.system('lab/report/update'), data);
}

/**
 * 删除检测报告
 * @param params 删除参数，包含 id
 * @returns 返回操作结果
 */
async function deleteReport(params: { id: number }) {
  return requestClient.delete(apiPath.system('lab/report/delete'), { params });
}

export {
  addReport,
  deleteReport,
  getReportById,
  getReportList,
  updateReport,
};
```

**规则**：
- **API 文件位置**：`apps/lab-admin/src/api/{module}/{entity}.ts`（如 `api/lab/report.ts`）
- **数据类型定义**：使用 `namespace` 导出，参考 SQL 数据结构定义接口
- **接口命名**：列表接口使用 `get{Entity}List`，详情接口使用 `get{Entity}ById`，新增接口使用 `add{Entity}`，更新接口使用 `update{Entity}`，删除接口使用 `delete{Entity}`
- **函数注释**：所有函数必须有完整的 JSDoc 注释，包括方法描述、参数类型和返回值说明
- **类型导出**：在 `api/index.ts` 中统一导出，便于使用

