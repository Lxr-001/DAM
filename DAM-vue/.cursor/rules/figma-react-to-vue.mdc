```typescript
// React (Figma)
interface Props {
  title: string;
  count?: number;
}

type Status = 'active' | 'inactive';

// Vue (项目规范)
// 保持相同的接口和类型定义
interface Props {
  title: string;
  count?: number;
}

// 避免枚举，使用映射
const STATUS_MAP = {
  active: 'active',
  inactive: 'inactive',
} as const;

type Status = typeof STATUS_MAP[keyof typeof STATUS_MAP];
```

